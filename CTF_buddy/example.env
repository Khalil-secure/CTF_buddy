# Copy this file to .env and fill in ONE backend (or both — AWS takes priority if both are set)

# ── Option A: AWS Bedrock (default) ─────────────────────────────────────────
# Get credentials from AWS console or a workshop STS token
AWS_DEFAULT_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=        # only needed for temporary STS credentials

# ── Option B: Anthropic API ──────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
# If ANTHROPIC_API_KEY is set and AWS credentials are absent, this backend is used
ANTHROPIC_API_KEY=
